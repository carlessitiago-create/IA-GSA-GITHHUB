import React, { useEffect, useState } from 'react';
import { 
  collection, 
  query, 
  where, 
  onSnapshot, 
  orderBy 
} from 'firebase/firestore';
import { db } from '../../firebase';
import { useAuth } from '../AuthContext';
import { 
  Clock, 
  CheckCircle2, 
  AlertCircle, 
  FileText, 
  ChevronRight,
  Shield,
  MessageSquare
} from 'lucide-react';
import { OrderProcess } from '../../services/orderService';
import { motion, AnimatePresence } from 'motion/react';
import { PendencyList } from './PendencyList';

export const ClientProcessesView: React.FC = () => {
  const { profile } = useAuth();
  const [processes, setProcesses] = useState<OrderProcess[]>([]);
  const [loading, setLoading] = useState(true);
  const [selectedProcess, setSelectedProcess] = useState<OrderProcess | null>(null);

  useEffect(() => {
    if (!profile) return;

    const q = query(
      collection(db, 'order_processes'),
      where('cliente_id', '==', profile.uid),
      orderBy('data_venda', 'desc')
    );

    const unsubscribe = onSnapshot(q, (snapshot) => {
      setProcesses(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as OrderProcess)));
      setLoading(false);
    }, (error) => {
      console.error("Erro ao buscar processos do cliente:", error);
      setLoading(false);
    });

    return () => unsubscribe();
  }, [profile]);

  if (loading) {
    return (
      <div className="p-12 flex justify-center">
        <div className="animate-spin rounded-full h-12 w-12 border-4 border-blue-500 border-t-transparent"></div>
      </div>
    );
  }

  const getStatusColor = (status: string) => {
    switch (status) {
      case 'Concluído': return 'text-emerald-400 bg-emerald-400/10';
      case 'Em Andamento': return 'text-blue-400 bg-blue-400/10';
      case 'Aguardando Documentação': return 'text-rose-400 bg-rose-400/10';
      case 'Em Análise': return 'text-amber-400 bg-amber-400/10';
      default: return 'text-slate-400 bg-slate-400/10';
    }
  };

  return (
    <div className="space-y-8 pb-24">
      {/* HEADER DE SEÇÃO */}
      <div className="px-4 md:px-0 mt-8">
        <h2 className="text-3xl md:text-5xl font-black italic uppercase text-white leading-tight">Meus <br/><span className="text-blue-500">Processos Ativos.</span></h2>
        <p className="text-slate-500 text-sm mt-2">Acompanhe em tempo real a evolução de cada etapa jurídica e tecnológica.</p>
      </div>

      {/* PENDÊNCIAS CRÍTICAS (Se houver) */}
      <section className="px-4 md:px-0">
        <PendencyList />
      </section>

      {/* LISTA DE PROCESSOS */}
      <section className="px-4 md:px-0 space-y-4">
        <div className="flex items-center gap-2 mb-6">
          <div className="h-px flex-1 bg-white/5"></div>
          <h3 className="text-[10px] font-black text-slate-500 uppercase tracking-[0.3em]">Histórico de Contratações</h3>
          <div className="h-px flex-1 bg-white/5"></div>
        </div>

        {processes.length === 0 ? (
          <div className="bg-white/3 border border-dashed border-white/10 rounded-[2.5rem] p-16 text-center flex flex-col items-center">
            <FileText className="text-slate-700 mb-4" size={48} />
            <p className="text-slate-500 font-bold">Você ainda não possui processos ativos.</p>
            <p className="text-[10px] text-slate-600 uppercase mt-1">Explore a Vitrine para iniciar sua jornada.</p>
          </div>
        ) : (
          <div className="grid grid-cols-1 gap-4">
            {processes.map((p, idx) => (
              <motion.div 
                key={p.id}
                initial={{ opacity: 0, x: -20 }}
                animate={{ opacity: 1, x: 0 }}
                transition={{ delay: idx * 0.05 }}
                className="bg-white/3 backdrop-blur-md border border-white/5 rounded-[2rem] p-6 hover:bg-white/5 transition-all group cursor-pointer"
                onClick={() => setSelectedProcess(p)}
              >
                <div className="flex flex-col md:flex-row md:items-center justify-between gap-6">
                  <div className="flex items-center gap-4">
                    <div className={`size-14 rounded-2xl flex items-center justify-center ${getStatusColor(p.status_atual)}`}>
                      <Shield size={28} />
                    </div>
                    <div>
                      <div className="flex items-center gap-2 mb-1">
                        <span className="text-[9px] font-black text-slate-500 uppercase tracking-widest">Protocolo: {p.protocolo}</span>
                        <span className={`px-2 py-0.5 rounded text-[8px] font-black uppercase tracking-widest ${getStatusColor(p.status_atual)}`}>
                          {p.status_atual}
                        </span>
                      </div>
                      <h4 className="text-xl font-black italic uppercase text-white tracking-tight leading-tight">{p.servico_nome}</h4>
                      <div className="flex items-center gap-3 mt-1">
                        <div className="flex items-center gap-1 text-[10px] font-bold text-slate-500 uppercase">
                          <Clock size={12} /> Prazo: {p.prazo_estimado_dias} Dias
                        </div>
                        {p.data_venda && (
                          <div className="flex items-center gap-1 text-[10px] font-bold text-slate-500 uppercase">
                            <CheckCircle2 size={12} /> Início: {p.data_venda.toDate().toLocaleDateString()}
                          </div>
                        )}
                      </div>
                    </div>
                  </div>

                  <div className="flex items-center gap-4">
                    <div className="text-right hidden md:block">
                      <p className="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-1">Status Interno</p>
                      <p className="text-xs font-bold text-slate-300 italic">{p.status_info_extra || 'Processando informações...'}</p>
                    </div>
                    <div className="size-12 rounded-full border border-white/10 flex items-center justify-center group-hover:bg-blue-600 group-hover:border-blue-600 transition-all">
                      <ChevronRight size={20} className="text-white" />
                    </div>
                  </div>
                </div>
              </motion.div>
            ))}
          </div>
        )}
      </section>

      {/* MODAL DE DETALHES DO PROCESSO */}
      <AnimatePresence>
        {selectedProcess && (
          <div className="fixed inset-0 z-[110] flex items-center justify-center p-4 bg-black/90 backdrop-blur-2xl">
            <motion.div 
              initial={{ opacity: 0, scale: 0.9, y: 20 }}
              animate={{ opacity: 1, scale: 1, y: 0 }}
              exit={{ opacity: 0, scale: 0.9, y: 20 }}
              className="bg-[#0a0a2e] w-full max-w-4xl rounded-[3rem] overflow-hidden border border-white/10 shadow-2xl relative"
            >
              <button 
                onClick={() => setSelectedProcess(null)}
                className="absolute top-6 right-6 z-10 size-10 bg-white/5 hover:bg-white/10 rounded-full flex items-center justify-center text-white transition-all"
              >
                <X size={20} />
              </button>

              <div className="p-8 md:p-12">
                <div className="flex items-center gap-4 mb-8">
                  <div className={`size-16 rounded-[1.5rem] flex items-center justify-center ${getStatusColor(selectedProcess.status_atual)}`}>
                    <Shield size={32} />
                  </div>
                  <div>
                    <span className="text-[10px] font-black text-blue-400 uppercase tracking-[0.3em]">Detalhes do Protocolo</span>
                    <h3 className="text-3xl md:text-5xl font-black italic uppercase text-white leading-tight">{selectedProcess.servico_nome}</h3>
                  </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                  <div className="bg-white/5 p-6 rounded-3xl border border-white/5">
                    <p className="text-[9px] font-black text-slate-500 uppercase mb-2 tracking-widest">Status Atual</p>
                    <p className={`text-lg font-black italic uppercase ${getStatusColor(selectedProcess.status_atual).split(' ')[0]}`}>
                      {selectedProcess.status_atual}
                    </p>
                  </div>
                  <div className="bg-white/5 p-6 rounded-3xl border border-white/5">
                    <p className="text-[9px] font-black text-slate-500 uppercase mb-2 tracking-widest">Protocolo</p>
                    <p className="text-lg font-black italic uppercase text-white">
                      {selectedProcess.protocolo}
                    </p>
                  </div>
                  <div className="bg-white/5 p-6 rounded-3xl border border-white/5">
                    <p className="text-[9px] font-black text-slate-500 uppercase mb-2 tracking-widest">Data Contratação</p>
                    <p className="text-lg font-black italic uppercase text-white">
                      {selectedProcess.data_venda?.toDate().toLocaleDateString()}
                    </p>
                  </div>
                </div>

                <div className="space-y-6">
                  <div className="flex items-center gap-2">
                    <MessageSquare size={18} className="text-blue-500" />
                    <h4 className="text-xs font-black text-slate-400 uppercase tracking-widest">Mensagem do Consultor</h4>
                  </div>
                  <div className="bg-blue-500/5 border border-blue-500/10 p-6 rounded-[2rem]">
                    <p className="text-slate-300 italic leading-relaxed">
                      {selectedProcess.status_info_extra || "Seu processo está sendo analisado por nossa equipe técnica. Em breve teremos novas atualizações."}
                    </p>
                  </div>
                </div>

                <div className="mt-12 flex justify-end">
                  <button 
                    onClick={() => setSelectedProcess(null)}
                    className="bg-white text-black px-12 py-5 rounded-2xl font-black uppercase text-[10px] tracking-widest hover:scale-105 transition-all"
                  >
                    Fechar Detalhes
                  </button>
                </div>
              </div>
            </motion.div>
          </div>
        )}
      </AnimatePresence>
    </div>
  );
};

const X: React.FC<{ size?: number }> = ({ size = 24 }) => (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round">
    <path d="M18 6L6 18M6 6l12 12" />
  </svg>
);
